{
  "name": "@afilmory/monorepo",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/vsxd/afilmory-vercel"
  },
  "scripts": {
    "audit:prod": "pnpm audit --registry=https://registry.npmjs.org --prod --audit-level=high",
    "build": "pnpm exec tsx apps/web/scripts/precheck.ts && pnpm build:packages && pnpm build:web",
    "build:manifest": "BUILDER_CONFIG_PATH=builder.config.ts pnpm --filter @afilmory/builder cli",
    "build:packages": "pnpm --filter @afilmory/builder build && pnpm --filter @afilmory/webgl-viewer build",
    "build:web": "pnpm --filter @afilmory/web build",
    "dev": "pnpm --filter @afilmory/web dev",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/root",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "preview": "pnpm --filter @afilmory/web serve",
    "test": "pnpm --filter @afilmory/schema test && pnpm --filter @afilmory/media test && pnpm --filter @afilmory/ui test && pnpm --filter @afilmory/builder test && pnpm --filter @afilmory/webgl-viewer test && pnpm --filter @afilmory/web test && pnpm exec vitest run --project scripts",
    "test:e2e": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "test:e2e:install": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright install chromium",
    "type-check": "pnpm --filter @afilmory/schema type-check && pnpm --filter @afilmory/media type-check && pnpm --filter @afilmory/ui type-check && pnpm --filter @afilmory/builder type-check && pnpm --filter @afilmory/webgl-viewer type-check && pnpm --filter @afilmory/web type-check"
  },
  "devDependencies": {
    "@afilmory/builder": "workspace:*",
    "@afilmory/schema": "workspace:*",
    "@afilmory/ui": "workspace:*",
    "@playwright/test": "1.60.0",
    "@t3-oss/env-core": "catalog:",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.9.2",
    "ast-kit": "2.1.3",
    "consola": "3.4.2",
    "dotenv-expand": "catalog:",
    "es-toolkit": "1.41.0",
    "eslint": "9.38.0",
    "eslint-config-hyoban": "4.0.10",
    "fast-glob": "^3.3.2",
    "jsdom": "^29.0.2",
    "lint-staged": "16.2.6",
    "nbump": "2.1.8",
    "opentype.js": "1.3.4",
    "prettier": "3.6.2",
    "sharp": "0.34.4",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "catalog:",
    "tsx": "4.22.4",
    "typescript": "catalog:",
    "unplugin-ast": "0.15.3",
    "vite": "7.1.12",
    "vite-bundle-analyzer": "1.2.3",
    "vite-plugin-checker": "0.11.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "^3",
    "zod": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --ignore-path ./.gitignore --write "
    ],
    "*.{js,ts,cjs,mjs,jsx,tsx,json}": [
      "eslint --fix"
    ]
  }
}
